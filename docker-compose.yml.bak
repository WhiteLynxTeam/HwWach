version: '3.8'

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: hwwach_app
    ports:
      - "8080:8080"
    environment:
      - SERVER_ADDRESS=:8080
      - DATABASE_DSN=host=postgres user=hwwach dbname=hwwach sslmode=disable password=hwwach_secret
      - JWT_SECRET=your_super_secret_jwt_key_change_in_production
      - MINIO_ENDPOINT=minio:9000
      - MINIO_ACCESS_KEY=hwwach_minio_key
      - MINIO_SECRET_KEY=hwwach_minio_secret
      - MINIO_USE_SSL=false
      - MINIO_BUCKET=photos
      - TZ=Europe/Moscow
    depends_on:
      postgres:
        condition: service_healthy
      minio:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - hwwach_network

  postgres:
    image: postgres:16-alpine
    container_name: hwwach_postgres
    environment:
      - POSTGRES_USER=hwwach
      - POSTGRES_PASSWORD=hwwach_secret
      - POSTGRES_DB=hwwach
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hwwach -d hwwach"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped
    networks:
      - hwwach_network

  minio:
    image: minio/minio:RELEASE.2024-04-18T19-09-19Z
    container_name: hwwach_minio
    command: server /data --console-address ":9001"
    environment:
      - MINIO_ROOT_USER=hwwach_minio_key
      - MINIO_ROOT_PASSWORD=hwwach_minio_secret
    volumes:
      - minio_data:/data
    ports:
      - "9000:9000"
      - "9001:9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3
    restart: unless-stopped
    networks:
      - hwwach_network

volumes:
  postgres_data:
    driver: local
  minio_data:
    driver: local

networks:
  hwwach_network:
    driver: bridge
